generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  name      String
  lastName  String?
  role      String   // deposit_manager, operator, supervisor, project_manager, ammo_manager
  email     String   @unique
  password  String   // Will be hashed
  status    String   @default("active") // active, inactive
  createdAt DateTime @default(now())
}

model Vehicle {
  id          String   @id @default(uuid())
  ni          String   @unique
  origen_unit String
  status      String   @default("in_army") // in_army, in_deposit, in_plant, in_service
  army_status String   @default("uninspected") // uninspected, selected, discarded
  entry_date  DateTime @default(now())
  status_updated_at DateTime @default(now()) // fecha desde la que el vehículo está en su status actual
  assigned_operators String[] @default([])

  activities  VehicleActivity[]
  ammunition  VehicleAmmunitionAssignment[]
}

model Activity {
  id              String   @id @default(uuid())
  name            String
  suggested_order Int

  checklists      ChecklistItem[]
  vehicleActs     VehicleActivity[]
}

model ChecklistItem {
  id          String   @id @default(uuid())
  activity_id String
  description String

  activity    Activity @relation(fields: [activity_id], references: [id], onDelete: Cascade)
  vehicleItems VehicleChecklistItem[]
}

model Supply {
  id          String   @id @default(uuid())
  name        String
  description String?
  family      String?

  batches     SupplyBatch[]
}

model SupplyBatch {
  id                 String   @id @default(uuid())
  supply_id          String
  batch_number       String?
  serial_numbers     String[] // PostgreSQL array of strings
  available_quantity Int      @default(1)
  entry_date         DateTime @default(now())

  supply             Supply   @relation(fields: [supply_id], references: [id], onDelete: Cascade)
  consumptions       ActivityMaterialConsumption[]
}

model VehicleActivity {
  id            String   @id @default(uuid())
  vehicle_id    String
  activity_id   String
  status        String   @default("pending") // pending, in_progress, pending_review, completed
  operator_id   String?
  supervisor_id String?
  rejection_reason String?
  started_at    DateTime?
  completed_at  DateTime?
  verified_at   DateTime?

  vehicle       Vehicle  @relation(fields: [vehicle_id], references: [id], onDelete: Cascade)
  activity      Activity @relation(fields: [activity_id], references: [id], onDelete: Cascade)
  
  checklistItems VehicleChecklistItem[]
  consumptions   ActivityMaterialConsumption[]
}

model VehicleChecklistItem {
  id                  String   @id @default(uuid())
  vehicle_activity_id String
  checklist_id        String
  is_completed        Boolean  @default(false)
  started_at          DateTime?
  completed_at        DateTime?
  operator_id         String?

  vehicleActivity     VehicleActivity @relation(fields: [vehicle_activity_id], references: [id], onDelete: Cascade)
  checklistItem       ChecklistItem   @relation(fields: [checklist_id], references: [id], onDelete: Cascade)
}

model ActivityMaterialConsumption {
  id                  String   @id @default(uuid())
  vehicle_activity_id String
  supply_batch_id     String
  serial_number       String?
  quantity_used       Int
  operator_id         String
  timestamp           DateTime @default(now())

  vehicleActivity     VehicleActivity @relation(fields: [vehicle_activity_id], references: [id], onDelete: Cascade)
  supplyBatch         SupplyBatch     @relation(fields: [supply_batch_id], references: [id], onDelete: Cascade)
}

model AuditLog {
  id          String   @id @default(uuid())
  user_id     String
  action      String
  entity_type String
  entity_id   String
  old_value   String?
  new_value   String?
  timestamp   DateTime @default(now())
}

model Ammunition {
  id          String   @id @default(uuid())
  type        String
  caliber     String?
  description String?

  batches     AmmunitionBatch[]
}

model AmmunitionBatch {
  id                 String   @id @default(uuid())
  ammunition_id      String
  batch_number       String?
  available_quantity Int      @default(0)
  entry_date         DateTime @default(now())
  
  ammunition         Ammunition @relation(fields: [ammunition_id], references: [id], onDelete: Cascade)
  assignments        VehicleAmmunitionAssignment[]
}

model VehicleAmmunitionAssignment {
  id                  String   @id @default(uuid())
  vehicle_id          String
  ammunition_batch_id String
  quantity            Int
  operator_id         String
  assigned_at         DateTime @default(now())
  
  vehicle             Vehicle  @relation(fields: [vehicle_id], references: [id], onDelete: Cascade)
  batch               AmmunitionBatch @relation(fields: [ammunition_batch_id], references: [id], onDelete: Cascade)
}
